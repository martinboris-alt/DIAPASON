# EmailJS — https://www.emailjs.com/
# 1. Crea una cuenta en EmailJS
# 2. Crea un servicio (Gmail, Outlook, etc.) y copia el Service ID
# 3. Crea una plantilla con variables: {{from_name}}, {{from_email}}, {{phone}}, {{service}}, {{message}}
# 4. Copia tu Public Key desde Account > API Keys

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
